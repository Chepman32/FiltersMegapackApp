+    private func resolvedPreviewCornerRadius() -> CGFloat {
+        if self.layer.cornerRadius > 0 {
+            return self.layer.cornerRadius
+        }
+
+        let candidate = self.subviews
+            .filter { !$0.isHidden && $0.alpha > 0.01 && !$0.bounds.isEmpty }
+            .max { left, right in
+                (left.bounds.width * left.bounds.height) < (right.bounds.width * right.bounds.height)
+            }
+
+        return candidate?.layer.cornerRadius ?? fallbackPreviewCornerRadius
+    }
+
+    private func makeRenderedPreviewView() -> UIView {
+        let renderer = UIGraphicsImageRenderer(bounds: self.bounds)
+        let image = renderer.image { context in
+            if !self.drawHierarchy(in: self.bounds, afterScreenUpdates: false) {
+                self.layer.render(in: context.cgContext)
+            }
+        }
+
+        let imageView = UIImageView(image: image)
+        imageView.frame = self.bounds
+        imageView.backgroundColor = .clear
+        imageView.contentMode = .scaleToFill
+        imageView.layer.cornerRadius = resolvedPreviewCornerRadius()
+        imageView.layer.masksToBounds = true
+        return imageView
+    }
+
+    private func makeTargetedPreview() -> UITargetedPreview? {
+        guard !self.bounds.isEmpty else {
+            return nil
+        }
+
+        self.layoutIfNeeded()
+
+        let previewView = self.snapshotView(afterScreenUpdates: false) ?? makeRenderedPreviewView()
+        previewView.frame = self.bounds
+        previewView.backgroundColor = .clear
+
+        let parameters = UIPreviewParameters()
+        parameters.backgroundColor = .clear
+        parameters.visiblePath = UIBezierPath(
+            roundedRect: self.bounds,
+            cornerRadius: resolvedPreviewCornerRadius()
+        )
+
+        let target = UIPreviewTarget(
+            container: self,
+            center: CGPoint(x: self.bounds.midX, y: self.bounds.midY)
+        )
+
+        return UITargetedPreview(view: previewView, parameters: parameters, target: target)
+    }
+
